# ============================================
# 𝙰 𝙿 Σ 𝚇 Userbot - Konfiqurasiya Faylı
# ============================================
# Bu faylı "config.env" adı ilə kopyalayın və dəyərləri doldurun
# QEYD: Bu fayl yalnız lokal test üçündür. HuggingFace-də Environment Variables istifadə edin!

# ============================================
# ƏSAS TƏNZİMLƏMƏLƏR (MÜTLƏQDİR!)
# ============================================

# Telegram API ID və Hash (https://my.telegram.org saytından alın)
API_KEY=12345678
API_HASH=abcdef1234567890abcdef1234567890

# String Session (Telegram @StringFatherBot-dan alın)
STRING_SESSION=buraya_string_session_kodu_yazin

# Log qrupunun ID-si (qrupda @userinfobot ilə öyrənin, mənfi rəqəm olmalıdır)
BOTLOG_CHATID=-100123456789

# Botlog aktivdir? (True və ya False)
BOTLOG=True

# ============================================
# ƏLAVƏ TƏNZİMLƏMƏLƏR (İSTƏYƏ BAĞLI)
# ============================================

# Bot dili (DEFAULT, AZ, TR, EN, UZ)
LANGUAGE=DEFAULT

# Alive mesajı üçün şəkil URL-i
IMG=https://telegra.ph/file/2d7769a2ee6ae14e567d6.jpg

# Alive mesajında görünəcək ad
ALIVE_NAME=

# Əmr prefiksi (nöqtə, vergül və s.)
PATTERNS=.,

# Plugin kanalının ID-si (pluginləri saxlamaq üçün)
PLUGIN_CHANNEL_ID=

# PM avtomatik ban (True və ya False)
PM_AUTO_BAN=False
PM_AUTO_BAN_LIMIT=4

# Avtomatik qruplara qoşulma (True və ya False)
AVTO_Q=True

# ============================================
# XARİCİ SERVİS API AÇARLARI (İSTƏYƏ BAĞLI)
# ============================================

# Last.fm (musiqi tracking)
LASTFM_API=
LASTFM_SECRET=
LASTFM_USERNAME=
LASTFM_PASSWORD=

# Genius (mahnı sözləri)
GENIUS=

# OpenWeatherMap (hava proqnozu)
OPEN_WEATHER_MAP_APPID=
WEATHER_DEFCITY=

# OCR Space (şəkildən mətn tanıma)
OCR_SPACE_API_KEY=

# Remove.bg (arxa fon silmə)
REM_BG_API_KEY=

# Google Drive
G_DRIVE_CLIENT_ID=
G_DRIVE_CLIENT_SECRET=
G_DRIVE_AUTH_TOKEN_DATA=
GDRIVE_FOLDER_ID=

# Spotify
SPOTIFY_DC=
SPOTIFY_KEY=

# YouTube API
YOUTUBE_API_KEY=

# Inline Bot (istəyə bağlı)
BOT_TOKEN=
BOT_USERNAME=

# ============================================
# VERİLƏNLƏR BAZASI
# ============================================
# Lokal test üçün SQLite (default)
DATABASE_URL=sqlite:///apex.db

# ============================================
# DİGƏR
# ============================================
CONSOLE_LOGGER_VERBOSE=False
LOGSPAMMER=False
